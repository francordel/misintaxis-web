---
import Layout from '../layouts/Page.astro'
import Container from '../components/Container.astro';
import SignupForm from '../components/SignupForm.astro';

const seo = {
  title: 'MiSintaxis | Aplicacion para aprendizaje de la sintaxis del español, analizador sintactico automatico',
  description: 'Aplicacion movil android ios y web de enseñanza de la sintaxis del español, contiene un analizador sintactico automatico y una herramienta para crear tus recursos como profesor para enseñar sintaxis con frases ya analizadas ',
}
---

<style>
  .hero__article {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    min-height: 70vh;
    text-align: center;
    padding: 2rem 0 3rem;
    width: 100%;
  }

  h1 {
    font-size: clamp(1.8rem, 5vw, 3rem);
    font-weight: bold;
    color: white;
    text-shadow:
      -1px -1px 0 black, 1px -1px 0 black,
      -1px  1px 0 black, 1px  1px 0 black;
  }

  p.fade-in {
    font-size: clamp(1rem, 3vw, 1.3rem);
    margin-bottom: 0.25rem;
  }
</style>

<Layout seo={seo}>
  <head>
    <!-- O si usas un archivo .png -->
    <link rel="icon" href="/favicon.png" type="image/png">
  </head>
  <Container narrow>
    <article class="hero__article">
      <h1 class="fade-in"></h1>
      <p class="fade-in">Introduce la frase que quieres que analicemos 🙃​</p>
      <SignupForm />
    </article>
  </Container>
</Layout>

